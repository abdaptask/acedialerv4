# Copy this file to .env at the repo root on the host. It is loaded into every
# pm2 service via Node --env-file (see ecosystem.config.cjs). Never commit a real .env file.

# ----- Database (self-hosted PostgreSQL on the app host) -----
DATABASE_URL="postgresql://postgres:[PASSWORD]@127.0.0.1:5432/acedialer"
DIRECT_DATABASE_URL="postgresql://postgres:[PASSWORD]@127.0.0.1:5432/acedialer"

# ----- Cache / Queue (Upstash Redis) -----
# From Upstash dashboard, "Details" tab
REDIS_URL="rediss://default:[PASSWORD]@xxxxx-us1.upstash.io:6379"

# ----- Telnyx -----
TELNYX_API_KEY="KEY..."
TELNYX_PUBLIC_KEY=""           # used to verify webhook signatures
TELNYX_MESSAGING_PROFILE_ID="" # filled in when first number is bought

# ----- Cloudflare TURN (v0.9.13 — optional failover for behind-NAT users)
# Telnyx TURN is always on (uses the user's SIP credentials, no env vars
# needed). Cloudflare TURN layers on as a secondary path for users where
# Telnyx TURN fails — typically users behind symmetric NATs in India / SE
# Asia or restrictive corporate networks. To enable:
#   1. dash.cloudflare.com → Calls → TURN (you may need to enable Calls first)
#   2. Create a TURN application; name it "ace-dialer"
#   3. Copy the Key ID and API Token, paste them below (in the repo-root .env
#      on the host), then `pm2 restart ace-api`.
# When unset, GET /turn-credentials returns an empty list and clients use
# Telnyx-TURN-only — which handles ~95% of NAT topologies on its own.
CLOUDFLARE_TURN_KEY_ID=""
CLOUDFLARE_TURN_API_TOKEN=""

# ----- JobDiva -----
JOBDIVA_USERNAME="as@aptask.com"
JOBDIVA_PASSWORD=""
JOBDIVA_CLIENT_ID=""
JOBDIVA_BASE_URL="https://api.jobdiva.com"

# ----- ElevenLabs -----
ELEVENLABS_API_KEY="sk_..."

# ----- Storage (Supabase Storage initially; switch to S3 later) -----
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ----- Auth -----
JWT_SECRET=""                 # any random 32+ character string for v0.1
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ----- Sentry (optional) -----
SENTRY_DSN=""

# ----- Service config -----
# pm2 sets PORT per service via ecosystem.config.cjs (api 3000, socket 3001, webhooks 3002, web 3010).
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ----- Allowed origins for CORS (comma-separated) -----
ALLOWED_ORIGINS="http://localhost:5173,https://dialer.aptask.com"

# ----- Microsoft Graph OAuth (apps/api/src/auth/microsoft.ts) -----
# Can reuse the same Azure App Registration as MS_CLIENT_ID/MS_TENANT_ID/MS_CLIENT_SECRET.
MS_GRAPH_CLIENT_ID=""
MS_GRAPH_CLIENT_SECRET=""
MS_GRAPH_TENANT_ID=""
MS_GRAPH_REDIRECT_URI="https://dialer.aptask.com/admin/microsoft/oauth/callback"
API_BASE_URL="https://dialer.aptask.com/api"   # fallback used to derive the redirect URI

# ----- Supabase Storage (MMS / voicemail / media uploads) -----
SUPABASE_URL="https://xxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""   # service-role key; server-side only, never expose to clients
SUPABASE_MEDIA_BUCKET="ace-media"

# ----- Webhooks / Telnyx voicemail -----
WEBHOOKS_ROUTE_PREFIX="/webhooks"
TELNYX_VOICEMAIL_CC_APP_ID=""

# ----- Email (SendGrid) -----
ACE_SUPPORT_EMAIL="support@aptask.com"
SENDGRID_FROM_NAME="ACE Dialer"

# ----- Telnyx cost reporting (optional; code has defaults when blank) -----
TELNYX_COST_INBOUND_PER_MIN=""
TELNYX_COST_OUTBOUND_PER_MIN=""
TELNYX_COST_PER_DID_MONTHLY=""
TELNYX_COST_PER_SMS=""

# ----- Pulse DB integration (optional; blank = disabled) -----
PULSE_DB_HOST=""
PULSE_DB_NAME=""
PULSE_DB_USER=""
PULSE_DB_PASS=""
PULSE_DB_PORT="5432"
PULSE_DB_SSL=""

# ----- Desktop (Electron) overrides -----
ACE_DEVTOOLS=""   # set to "1" to open Electron devtools on launch
