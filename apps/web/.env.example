# Web client config. Vite exposes only VITE_-prefixed vars to client code.

# Backend
VITE_API_URL=https://dialer.aptask.com/api

# SIP credentials are per-user and come from login (stored in sessionStorage),
# NOT from build-time env vars. There is no shared VITE_SIP_* fallback.

# Optional overrides (baked at build time; defaults apply when blank)
VITE_SIP_WSS_URI=wss://sip.telnyx.com:7443
VITE_FORCE_ABSOLUTE_BASE=
