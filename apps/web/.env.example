# Web client config. Vite exposes only VITE_-prefixed vars to client code.

# Backend
VITE_API_URL=https://ace-dialer-api.onrender.com

# SIP (Telnyx) — needed to register and place real calls
VITE_SIP_WS_URL=wss://sip.telnyx.com:7443
VITE_SIP_DOMAIN=sip.telnyx.com
VITE_SIP_USERNAME=your_telnyx_sip_username
VITE_SIP_PASSWORD=your_telnyx_sip_password
