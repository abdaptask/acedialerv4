<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required by Electron's V8 JIT under macOS Hardened Runtime.
       Hardened Runtime forbids JIT by default; these three keys opt in. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Microphone access for SIP/WebRTC calls. Combined with the
       NSMicrophoneUsageDescription string in Info.plist this makes macOS
       show the permission prompt on first call attempt. -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
  <key>com.apple.security.device.microphone</key>
  <true/>

  <!-- Outbound HTTPS / WSS to Render + Telnyx. -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Inbound RTP for SIP media (WebRTC peer-to-peer). -->
  <key>com.apple.security.network.server</key>
  <true/>
</dict>
</plist>
