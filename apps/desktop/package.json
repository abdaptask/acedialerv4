{
  "name": "@ace/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "ACE Dialer desktop app (Electron)",
  "author": "ApTask",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "electron .",
    "dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "package": "electron-builder",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.aptask.acedialer",
    "productName": "ACE Dialer",
    "electronVersion": "31.7.7",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web",
        "filter": ["**/*"]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": ["tray-icon*.png"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "publisherName": "ApTask"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ACE Dialer"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.business",
      "hardenedRuntime": false
    },
    "linux": {
      "target": ["AppImage"]
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "cross-env": "^7.0.3",
    "electron": "31.7.7",
    "electron-builder": "^25.0.0",
    "typescript": "^5.4.5"
  }
}
