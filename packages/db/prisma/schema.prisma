// ACE Dialer 2.0 — Prisma schema.
// Phase 1: users.
// Phase 5.1: calls.
// Phase 5.3: messages (SMS/MMS).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  /// Local-password hash (bcrypt). NULL for users who only sign in via
  /// Microsoft SSO. Kept nullable so we can support a small set of break-glass
  /// local accounts (admins) alongside SSO users.
  passwordHash    String?   @map("password_hash")
  firstName       String?   @map("first_name")
  lastName        String?   @map("last_name")
  phoneExtension  String?   @map("phone_extension")
  sipPassword     String?   @map("sip_password")
  jobDivaUserId   String?   @map("jobdiva_user_id")
  /// Phase 5.7 (multi-user): the Telnyx SIP credential username this user logs
  /// into the WebRTC SDK with. Used by the webhook handler to route call
  /// events back to the right user (matching on the SIP user that initiated
  /// or received the leg).
  sipUsername     String?   @unique @map("sip_username")
  /// Phase 5.7 (multi-user): the DID (E.164 phone number) assigned to this
  /// user. Used by the webhook handler to route inbound SMS/calls to the
  /// right user (matching on the called number).
  didNumber       String?   @unique @map("did_number")
  /// Telnyx-side internal id for the DID. Avoids re-looking it up on every
  /// call-forwarding save. Populated lazily by the API the first time the
  /// user opens Settings → Call Forwarding (or via the create-user script).
  telnyxNumberId  String?   @map("telnyx_number_id")
  /// Call Forwarding (Pulse-pattern feature).
  /// - forwardingEnabled: toggle in Settings.
  /// - forwardingNumber: destination E.164.
  /// - forwardingMode: "always" (every call) or "on_failure" (only when
  ///   the dialer doesn't answer; falls through to voicemail if also unset).
  forwardingEnabled Boolean   @default(false) @map("forwarding_enabled")
  forwardingNumber  String?   @map("forwarding_number")
  forwardingMode    String?   @map("forwarding_mode")
  /// Public URL of the user's uploaded voicemail greeting audio file
  /// (stored in Supabase `ace-media` bucket). Telnyx fetches this URL
  /// when a call falls to voicemail. Null = use Telnyx's default greeting.
  voicemailGreetingUrl      String? @map("voicemail_greeting_url")
  voicemailGreetingFilename String? @map("voicemail_greeting_filename")
  isAdmin         Boolean   @default(false) @map("is_admin")
  isActive        Boolean   @default(true)  @map("is_active")
  /// Microsoft Entra ID immutable user id ("oid" claim on the id_token).
  /// Survives email renames. NULL for break-glass local-password accounts.
  azureOid        String?   @unique @map("azure_oid")
  /// Which auth provider the user signs in with. "microsoft" is the
  /// default for new ApTask SSO users; "local" is the break-glass model.
  provider        String    @default("microsoft")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  calls           Call[]
  messages        Message[]
  voicemails      Voicemail[]
  internalSent       InternalMessage[] @relation("InternalMessageSender")
  internalReceived   InternalMessage[] @relation("InternalMessageRecipient")
  blockedNumbers     BlockedNumber[]
  favorites          Favorite[]
  auditLogsAuthored  AuditLog[]        @relation("AuditLogActor")
  auditLogsTargeting AuditLog[]        @relation("AuditLogTarget")

  @@map("users")
}

/// Per-user starred contacts. Used to power the Favorites tab and to show
/// friendly names in Recents / Incoming / InCall when the caller matches a
/// favorite. Synced across all of the user's devices via the API — replaces
/// the localStorage-only store that used to live in lib/userPrefs.ts.
/// Phone is stored E.164 normalized. Matching is on the full E.164 string;
/// callers should normalize before lookup (toE164 helper).
model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String   // E.164 normalized
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  /// Optional pre-joined display label. Kept for back-compat with old clients
  /// that wrote a plain label string; new clients write firstName+lastName.
  label     String?
  addedAt   DateTime @default(now()) @map("added_at")

  @@unique([userId, phone])
  @@index([userId])
  @@map("favorites")
}

/// Phase 6.8 — Number blocking.
/// Per-user list of phone numbers that should be silently dropped on
/// inbound (calls hang up immediately; SMS is dropped without storing).
/// Stored in E.164 form. The check in webhooks compares last-10 digits
/// to be tolerant of carrier-formatting differences (matches the rest
/// of the dialer's phone-matching convention).
model BlockedNumber {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  number    String   // E.164 normalized
  reason    String?  // optional free-text label (e.g. "spam", "ex")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, number])
  @@index([userId])
  @@map("blocked_numbers")
}

model Call {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  user            User      @relation(fields: [userId], references: [id])
  telnyxCallId    String    @unique @map("telnyx_call_id")
  sessionId       String?   @map("session_id")
  /// Telnyx Voice API Call Control ID, populated by the webhook handler when
  /// Call Control is enabled on the SIP connection. Needed to bridge two legs
  /// into a 3-way conference.
  callControlId   String?   @map("call_control_id")
  direction       String    // 'inbound' | 'outbound'
  fromNumber      String    @map("from_number")
  toNumber        String    @map("to_number")
  status          String    // 'initiated' | 'ringing' | 'answered' | 'completed' | 'failed' | 'missed' | 'no_answer' | 'rejected'
  startedAt       DateTime  @map("started_at")
  answeredAt      DateTime? @map("answered_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int       @default(0) @map("duration_seconds")
  hangupCause     String?   @map("hangup_cause")
  hangupSource    String?   @map("hangup_source")
  recordingUrl    String?   @map("recording_url")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  @@index([userId, startedAt])
  @@map("calls")
}

// Phase 5.3 — SMS/MMS.
// threadKey is the OTHER party's E.164 number (regardless of direction) so
// inbound and outbound texts to the same contact share one thread.
model Message {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  user             User      @relation(fields: [userId], references: [id])
  telnyxMessageId  String    @unique @map("telnyx_message_id")
  threadKey        String    @map("thread_key")
  direction        String    // 'inbound' | 'outbound'
  fromNumber       String    @map("from_number")
  toNumber         String    @map("to_number")
  body             String    @default("")
  mediaUrls        String[]  @default([]) @map("media_urls")
  status           String    @default("queued") // queued | sent | delivered | failed | received
  errors           Json?
  sentAt           DateTime? @map("sent_at")
  deliveredAt      DateTime? @map("delivered_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt      @map("updated_at")

  @@index([userId, threadKey, createdAt])
  @@index([userId, createdAt])
  @@map("messages")
}

// Phase 5.6 — Voicemail.
// Populated by the webhook when Telnyx finishes recording an unanswered call.
model Voicemail {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  user            User      @relation(fields: [userId], references: [id])
  telnyxCallId    String?   @map("telnyx_call_id")
  /// Caller's E.164 number.
  fromNumber      String    @map("from_number")
  /// The DID the caller dialed (our number).
  toNumber        String    @map("to_number")
  recordingUrl    String    @map("recording_url")
  durationSeconds Int       @default(0) @map("duration_seconds")
  transcription   String?
  /// When the caller hung up after leaving the message.
  receivedAt      DateTime  @map("received_at")
  listenedAt      DateTime? @map("listened_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  @@index([userId, receivedAt])
  @@map("voicemails")
}


// ---------------------------------------------------------------------------
// Internal Chat — dialer users messaging each other (NOT external SMS).
// One row per message. Threads are grouped by the {sender, recipient} pair
// (canonical key = sorted ids joined by '_' so it's the same regardless of
// which side sent the latest message).
// ---------------------------------------------------------------------------
model InternalMessage {
  id          Int       @id @default(autoincrement())
  senderId    Int       @map("sender_id")
  sender      User      @relation("InternalMessageSender", fields: [senderId], references: [id])
  recipientId Int       @map("recipient_id")
  recipient   User      @relation("InternalMessageRecipient", fields: [recipientId], references: [id])
  /// Canonical conversation key — e.g. "3_7" where 3 < 7. Lets us index +
  /// query a 1:1 thread cheaply regardless of which side sent last.
  threadKey   String    @map("thread_key")
  body        String    @default("")
  /// Optional URL to a media attachment (e.g. uploaded image, audio note).
  /// Reuses the Supabase Storage `ace-media` bucket the SMS/MMS flow uses.
  mediaUrl    String?   @map("media_url")
  /// When the recipient first opened the message. Drives the unread count.
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([threadKey, createdAt])
  @@index([recipientId, readAt])
  @@map("internal_messages")
}

// ---------------------------------------------------------------------------
// PendingUser — Pulse-to-ACE migration staging.
//
// Loaded from a CSV upload of existing Pulse users (firstName, lastName,
// email + their Telnyx-side voip_ext / voip_number / ext_password). Rows
// sit here doing NOTHING until an admin explicitly invites a specific user
// via POST /admin/pending-users/:id/invite.
//
// At invite time the admin picks 3 toggles in a modal:
//   1) New DID?            yes = Telnyx API buys a new number
//                          no  = use pulseVoipNumber as-is
//   2) New SIP creds?      yes = Telnyx API creates a fresh Credential
//                                Connection for this user
//                          no  = use pulseVoipExt + pulseExtPassword as-is
//   3) Repoint webhook?    yes = PATCH the Credential Connection's
//                                webhook_event_url from pulse.aptask.com
//                                to ACE's webhook (call logs flow to ACE)
//                          no  = leave webhook on Pulse
//
// Only on Confirm does any Telnyx state change. Successful invite creates
// the real User row, copies linkage into invitedUserId, sets status=invited.
// ---------------------------------------------------------------------------
model PendingUser {
  id                  Int       @id @default(autoincrement())
  firstName           String?   @map("first_name")
  lastName            String?   @map("last_name")
  email               String    @unique
  /// Pulse-side SIP username (CSV: voip_ext). Used as User.sipUsername if
  /// the admin picks "use existing creds" at invite.
  pulseVoipExt        String    @map("pulse_voip_ext")
  /// Pulse-side DID (CSV: voip_number, 10-digit US). Used as User.didNumber
  /// if the admin picks "use existing DID" at invite.
  pulseVoipNumber     String    @map("pulse_voip_number")
  /// Pulse-side SIP password (CSV: ext_password). Used as User.sipPassword
  /// if the admin picks "use existing creds" at invite.
  pulseExtPassword    String    @map("pulse_ext_password")
  /// Telnyx Credential Connection name (CSV: connection_name). Lets us look
  /// up the connection by name when we need to PATCH its webhook URL or
  /// route a new DID to it.
  pulseConnectionName String?   @map("pulse_connection_name")
  /// Pulse-internal status code (CSV: user_status). Kept for reference;
  /// not used by ACE logic.
  pulseUserStatus     String?   @map("pulse_user_status")
  /// Lifecycle: pending (default) → invited (admin clicked Confirm) or
  /// skipped (admin explicitly marked as "don't migrate"). Filter the
  /// admin UI by this column.
  status              String    @default("pending")
  /// When the admin clicked Confirm on the invite modal.
  invitedAt           DateTime? @map("invited_at")
  /// FK to the User row created at invite time. NULL until invited.
  /// Not a relation (avoids cascade-delete weirdness if a User is removed).
  invitedUserId       Int?      @map("invited_user_id")
  /// Each CSV upload gets a fresh UUID-style batch id so we can group
  /// "all rows from this upload" — useful for filtering and for the
  /// audit trail.
  importBatchId       String?   @map("import_batch_id")
  importedAt          DateTime  @default(now()) @map("imported_at")

  @@index([status])
  @@index([email])
  @@index([importBatchId])
  @@map("pending_users")
}

// ---------------------------------------------------------------------------
// AuditLog — enterprise hygiene. Every admin action (invite/promote/demote/
// deactivate/reset-password/role-change) writes a row here. Read-only for
// non-admins; admins see the full feed at Settings → Audit Log.
// ---------------------------------------------------------------------------
model AuditLog {
  id            Int       @id @default(autoincrement())
  /// Who performed the action. NULL only for system-generated entries
  /// (e.g. nightly cleanup jobs); admin actions always have an actor.
  actorUserId   Int?      @map("actor_user_id")
  actor         User?     @relation("AuditLogActor", fields: [actorUserId], references: [id])
  /// Dot-namespaced action verb — e.g. "user.invited", "user.promoted",
  /// "user.demoted", "user.deactivated", "user.password_reset",
  /// "user.sso_first_signin". Keep it sortable + filterable.
  action        String
  /// Which user the action targeted (null for non-user-targeted entries
  /// like "telnyx.webhook_replay_storm").
  targetUserId  Int?      @map("target_user_id")
  target        User?     @relation("AuditLogTarget", fields: [targetUserId], references: [id])
  /// Free-form context — old/new values for diffs, IP address, etc.
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}
