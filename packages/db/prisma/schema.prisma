// ACE Dialer 2.0 — Prisma schema.
// Phase 1: users.
// Phase 5.1: calls.
// Phase 5.3: messages (SMS/MMS).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  /// Local-password hash (bcrypt). NULL for users who only sign in via
  /// Microsoft SSO. Kept nullable so we can support a small set of break-glass
  /// local accounts (admins) alongside SSO users.
  passwordHash    String?   @map("password_hash")
  firstName       String?   @map("first_name")
  lastName        String?   @map("last_name")
  phoneExtension  String?   @map("phone_extension")
  sipPassword     String?   @map("sip_password")
  jobDivaUserId   String?   @map("jobdiva_user_id")
  /// Phase 5.7 (multi-user): the Telnyx SIP credential username this user logs
  /// into the WebRTC SDK with. Used by the webhook handler to route call
  /// events back to the right user (matching on the SIP user that initiated
  /// or received the leg).
  sipUsername     String?   @unique @map("sip_username")
  /// Phase 5.7 (multi-user): the DID (E.164 phone number) assigned to this
  /// user. Used by the webhook handler to route inbound SMS/calls to the
  /// right user (matching on the called number).
  ///
  /// v0.10.0 (feature/multi-num-teams-routing): DEPRECATED in favor of the
  /// UserDid relation below. Kept here for backwards compatibility — it
  /// shadows the user's default UserDid.didNumber. Any new code should
  /// look up via UserDid; reads of this column will be removed in v1.0.
  didNumber       String?   @unique @map("did_number")
  /// DEPRECATED — see UserDid.telnyxNumberId. Same v0.10.0 plan as didNumber.
  telnyxNumberId  String?   @map("telnyx_number_id")
  /// v0.10.0 — Pointer to the currently-selected outbound UserDid. When a
  /// user has multiple DIDs and toggles between them via the dialer header
  /// dropdown, this column tracks their choice server-side so it persists
  /// across logins and devices. Outbound SMS reads UserDid.didNumber via
  /// this pointer; outbound calls' caller ID is set by PATCHing the
  /// matching Credential Connection's ani_override at switch time.
  /// NULL = use whichever UserDid has isDefault=true.
  activeUserDidId Int?      @map("active_user_did_id")
  activeUserDid   UserDid?  @relation("UserActiveDid", fields: [activeUserDidId], references: [id])
  /// Call Forwarding (Pulse-pattern feature).
  /// - forwardingEnabled: toggle in Settings.
  /// - forwardingNumber: destination E.164.
  /// - forwardingMode: "always" (every call) or "on_failure" (only when
  ///   the dialer doesn't answer; falls through to voicemail if also unset).
  forwardingEnabled Boolean   @default(false) @map("forwarding_enabled")
  forwardingNumber  String?   @map("forwarding_number")
  forwardingMode    String?   @map("forwarding_mode")
  /// Public URL of the user's uploaded voicemail greeting audio file
  /// (stored in Supabase `ace-media` bucket). Telnyx fetches this URL
  /// when a call falls to voicemail. Null = use Telnyx's default greeting.
  voicemailGreetingUrl      String? @map("voicemail_greeting_url")
  voicemailGreetingFilename String? @map("voicemail_greeting_filename")
  isAdmin         Boolean   @default(false) @map("is_admin")
  isActive        Boolean   @default(true)  @map("is_active")
  /// Microsoft Entra ID immutable user id ("oid" claim on the id_token).
  /// Survives email renames. NULL for break-glass local-password accounts.
  azureOid        String?   @unique @map("azure_oid")
  /// Which auth provider the user signs in with. "microsoft" is the
  /// default for new ApTask SSO users; "local" is the break-glass model.
  provider        String    @default("microsoft")
  /// v0.10.0 Pillar 2 — DEPRECATED in v0.10.1.
  /// Was the user's personal Teams Incoming Webhook URL. Replaced by a
  /// tenant-wide Power Automate flow (TEAMS_TENANT_WEBHOOK_URL env var)
  /// so users don't have to do any per-user setup. Column kept nullable
  /// for now — notifier no longer reads it.
  teamsWebhookUrl String?   @map("teams_webhook_url")
  /// v0.10.1 Pillar 2 — Comma-separated opt-in list for which events
  /// trigger a Teams card. Values: 'missed_call', 'sms', 'voicemail'.
  /// DB default = all three so every new user starts opted-in. User
  /// edits via Settings → Personal → Teams notifications. Empty string
  /// = explicit opt-out of all events (we never auto-fill back).
  teamsNotifyOn   String?   @default("missed_call,sms,voicemail") @map("teams_notify_on")
  /// v0.10.79 — Comma-separated opt-in list for which events trigger an
  /// EMAIL notification (separate from teamsNotifyOn). Values: 'missed_call',
  /// 'sms', 'voicemail'. Default NULL = OFF for everyone (both existing AND
  /// newly invited users) — admins were burned-out by surprise notification
  /// floods on the Teams launch, so for the email channel we opt every user
  /// in opt-out-by-default. Users self-enable via Settings → Email
  /// notifications. Empty string also = opted out of all events.
  emailNotifyOn   String?   @map("email_notify_on")
  /// v0.10.60 — Per-user beta flag for the Connection Health overhaul.
  /// When true, this user gets: (a) UI smoothing of disconnect/reconnect
  /// status (transient blips hidden, amber "Reconnecting..." instead of
  /// red flicker), (b) server-pushed force-reconnect on Telnyx silent
  /// eviction (instead of waiting up to 10s for the heartbeat to notice).
  /// Default false during pilot; admin flips per user from Settings → Users.
  /// Once pilot validates the behavior, we flip the default to true in a
  /// follow-up migration.
  connectionHealthBeta Boolean @default(false) @map("connection_health_beta")
  /// v0.10.64 — Country tag for Telnyx anchor-site selection. "IN" → Chennai
  /// anchor; "US" or anything else → Latency-optimized anchor (existing
  /// default). Set when admin invites or migrates the user; defaults to NULL
  /// for existing users until admin fills it in. The migrate-from-pulse and
  /// invite-new-user flows pass this through to applyAceConnectionDefaults
  /// which PATCHes the new Credential Connection's anchorsite_override.
  country         String?   @map("country")
  /// v0.10.75 — Ringtone preference. One of: 'classic' | 'modern' | 'chime'
  /// | 'pulse'. NULL = use the system default ('classic'). User picks from
  /// Settings → Personal → Ringtone. Persisted server-side so the choice
  /// follows the user across devices.
  ringtone        String?   @map("ringtone")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  calls           Call[]
  messages        Message[]
  voicemails      Voicemail[]
  praisesSent     Praise[]    @relation("PraiseFrom")
  praisesReceived Praise[]    @relation("PraiseTo")
  praiseReads     PraiseRead[]
  internalSent       InternalMessage[] @relation("InternalMessageSender")
  internalReceived   InternalMessage[] @relation("InternalMessageRecipient")
  blockedNumbers     BlockedNumber[]
  favorites          Favorite[]
  scheduledMessages  ScheduledMessage[]
  auditLogsAuthored  AuditLog[]        @relation("AuditLogActor")
  auditLogsTargeting AuditLog[]        @relation("AuditLogTarget")
  /// v0.10.0 — Multi-DID support. Replaces the singular User.didNumber
  /// column. Each row represents one phone number this user owns. The row
  /// with isDefault=true is the user's primary line; activeUserDidId
  /// (pointer above) tracks whichever they currently have selected in
  /// the dialer header dropdown.
  userDids        UserDid[] @relation("UserOwnedDids")

  @@map("users")
}

/// v0.10.0 — Per-user phone-number ownership.
///
/// Replaces User.didNumber + User.telnyxNumberId (those two columns are now
/// deprecated and shadow the row that has isDefault=true; they'll be removed
/// in v1.0). A user can own N DIDs; the dialer header dropdown lets them
/// switch which one is the active outbound identity.
///
/// Future-proofing for ring groups + IVR: a DID can be bound either to a
/// single human user (the common case), a RingGroup (inbound calls fork to
/// multiple members), or an IvrMenu (inbound calls hit a TexML <Gather>
/// menu). The three target fields — userId, ringGroupId, ivrMenuId — are
/// mutually exclusive, enforced in application code at write time.
model UserDid {
  id              Int      @id @default(autoincrement())
  /// Owner. NULL only for DIDs bound to a RingGroup or IvrMenu that
  /// aren't tied to any specific admin user. Most DIDs have this set.
  userId          Int?     @map("user_id")
  user            User?    @relation("UserOwnedDids", fields: [userId], references: [id], onDelete: Cascade)
  /// Reverse relation for User.activeUserDidId pointer.
  activeFor       User[]   @relation("UserActiveDid")
  /// E.164 phone number. Globally unique — Telnyx owns the namespace.
  didNumber       String   @unique @map("did_number")
  /// Telnyx-side internal id for this DID. Cached so we don't re-lookup
  /// on every call-forwarding save / messaging-profile patch.
  telnyxNumberId  String?  @map("telnyx_number_id")
  /// Which Telnyx Credential Connection this DID's voice traffic is
  /// bound to. Cached for the same reason as telnyxNumberId.
  connectionId    String?  @map("connection_id")
  /// Display label shown in the dialer dropdown + on inbound rows.
  /// e.g. "Main", "Sales", "Personal". Defaults to "Line".
  label           String   @default("Line")
  /// Hex color for the inbound-DID tag pill that renders in Recents /
  /// Messages / Voicemail. Default = ACE blue.
  colorHex        String   @default("#3b82f6") @map("color_hex")
  /// Exactly one UserDid per user should have isDefault=true. Enforced
  /// in application code at the API layer.
  isDefault       Boolean  @default(false) @map("is_default")
  /// FUTURE (Pillar 3) — non-null binds this DID's inbound to a RingGroup
  /// instead of routing to the user's SIP credential.
  ringGroupId     Int?     @map("ring_group_id")
  /// FUTURE (Pillar 4) — non-null binds this DID's inbound to an IVR menu.
  /// Mutually exclusive with ringGroupId.
  ivrMenuId       Int?     @map("ivr_menu_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  /// v0.10.0 Task 5 — reverse relations for inbound DID flagging.
  /// Call/Message/Voicemail rows reference this UserDid via userDidId
  /// to surface a "line badge" in Recents / Messages / Voicemail.
  calls           Call[]
  messages        Message[]
  voicemails      Voicemail[]
  scheduledMessages ScheduledMessage[]

  @@index([userId])
  @@index([ringGroupId])
  @@index([ivrMenuId])
  @@map("user_dids")
}

/// Per-user starred contacts. Used to power the Favorites tab and to show
/// friendly names in Recents / Incoming / InCall when the caller matches a
/// favorite. Synced across all of the user's devices via the API — replaces
/// the localStorage-only store that used to live in lib/userPrefs.ts.
/// Phone is stored E.164 normalized. Matching is on the full E.164 string;
/// callers should normalize before lookup (toE164 helper).
model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// v0.10.66 — Kept as the "primary" phone for back-compat. New code reads
  /// the full list from FavoriteNumber. On v0.10.66 backfill, every existing
  /// Favorite gets one FavoriteNumber row with label="Mobile" containing
  /// this phone value. Future favorites still write this column on create
  /// (set to the primary number) so older clients that haven't picked up
  /// the multi-number UI yet continue to function.
  phone     String   // E.164 normalized
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  /// Optional pre-joined display label. Kept for back-compat with old clients
  /// that wrote a plain label string; new clients write firstName+lastName.
  label     String?
  addedAt   DateTime @default(now()) @map("added_at")

  /// v0.10.66 — One Favorite can now carry multiple labeled phone numbers
  /// (Cell, Home, Work, Other). The legacy Favorite.phone above is always
  /// mirrored as one of these rows for back-compat.
  numbers   FavoriteNumber[]

  @@unique([userId, phone])
  @@index([userId])
  @@map("favorites")
}

/// v0.10.66 — Multi-number favorites.
///
/// One Favorite can have many FavoriteNumber children (Cell/Home/Work/Other).
/// The favorite's display info (firstName, lastName) lives on Favorite;
/// each FavoriteNumber carries a label + an E.164 phone + a sort order.
///
/// Backfill (v0.10.66 migration): every existing Favorite row gets exactly
/// one FavoriteNumber created with label="Mobile" (per product decision),
/// phone=Favorite.phone, sortOrder=0, isPrimary=true.
model FavoriteNumber {
  id         Int      @id @default(autoincrement())
  favoriteId Int      @map("favorite_id")
  favorite   Favorite @relation(fields: [favoriteId], references: [id], onDelete: Cascade)
  /// E.164 normalized.
  phone      String
  /// Free-form label — but the UI offers Cell / Home / Work / Other as quick
  /// picks. Stored as plain text so admins can add their own (e.g. "Office",
  /// "Vacation", "Spouse"). Capped at 24 chars at API validation time.
  label      String   @default("Mobile")
  /// Display order within the favorite's number list. Lower = shown first.
  /// The primary number is sortOrder=0 by convention; UI adds 10/20/30 etc.
  sortOrder  Int      @default(0) @map("sort_order")
  /// True for exactly ONE number per favorite — the default tap target.
  /// Backfilled rows get isPrimary=true. New favorites set isPrimary=true
  /// on the first number added; admin can move primary later.
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt      @map("updated_at")

  /// Don't allow the same E.164 twice on the same favorite.
  @@unique([favoriteId, phone])
  @@index([favoriteId])
  @@map("favorite_numbers")
}

/// Phase 6.8 — Number blocking.
/// Per-user list of phone numbers that should be silently dropped on
/// inbound (calls hang up immediately; SMS is dropped without storing).
/// Stored in E.164 form. The check in webhooks compares last-10 digits
/// to be tolerant of carrier-formatting differences (matches the rest
/// of the dialer's phone-matching convention).
model BlockedNumber {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  number    String   // E.164 normalized
  reason    String?  // optional free-text label (e.g. "spam", "ex")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, number])
  @@index([userId])
  @@map("blocked_numbers")
}

model Call {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  user            User      @relation(fields: [userId], references: [id])
  telnyxCallId    String    @unique @map("telnyx_call_id")
  sessionId       String?   @map("session_id")
  /// Telnyx Voice API Call Control ID, populated by the webhook handler when
  /// Call Control is enabled on the SIP connection. Needed to bridge two legs
  /// into a 3-way conference.
  callControlId   String?   @map("call_control_id")
  direction       String    // 'inbound' | 'outbound'
  fromNumber      String    @map("from_number")
  toNumber        String    @map("to_number")
  status          String    // 'initiated' | 'ringing' | 'answered' | 'completed' | 'failed' | 'missed' | 'no_answer' | 'rejected'
  startedAt       DateTime  @map("started_at")
  answeredAt      DateTime? @map("answered_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int       @default(0) @map("duration_seconds")
  hangupCause     String?   @map("hangup_cause")
  hangupSource    String?   @map("hangup_source")
  recordingUrl    String?   @map("recording_url")
  /// v0.10.0 — Which of the user's DIDs this call landed on (inbound)
  /// or was placed from (outbound). NULL for legacy rows pre-backfill
  /// or for users that don't yet have any UserDid rows. Drives the line
  /// badge ("Sales", "Main") rendered on Recents rows in the UI.
  userDidId       Int?      @map("user_did_id")
  userDid         UserDid?  @relation(fields: [userDidId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  @@index([userId, startedAt])
  @@index([userDidId])
  @@map("calls")
}

// Phase 5.3 — SMS/MMS.
// threadKey is the OTHER party's E.164 number (regardless of direction) so
// inbound and outbound texts to the same contact share one thread.
model Message {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  user             User      @relation(fields: [userId], references: [id])
  telnyxMessageId  String    @unique @map("telnyx_message_id")
  threadKey        String    @map("thread_key")
  direction        String    // 'inbound' | 'outbound'
  fromNumber       String    @map("from_number")
  toNumber         String    @map("to_number")
  body             String    @default("")
  mediaUrls        String[]  @default([]) @map("media_urls")
  status           String    @default("queued") // queued | sent | delivered | failed | received
  errors           Json?
  sentAt           DateTime? @map("sent_at")
  deliveredAt      DateTime? @map("delivered_at")
  /// v0.10.26 — When this inbound message was first "seen" by the user
  /// (thread opened OR message explicitly marked read). Outbound messages
  /// are always considered read (you sent it). Used for unread counts,
  /// unread dots in the threads list, and 'New SMS' notifications.
  /// NULL = unread (only meaningful for inbound rows; outbound rows
  /// stay NULL too but the UI ignores readAt for outbound).
  readAt           DateTime? @map("read_at")
  /// v0.10.0 — Which of the user's DIDs this message landed on (inbound)
  /// or was sent from (outbound). NULL for legacy rows pre-backfill.
  /// See Call.userDidId for the design rationale.
  userDidId        Int?      @map("user_did_id")
  userDid          UserDid?  @relation(fields: [userDidId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt      @map("updated_at")

  @@index([userId, threadKey, createdAt])
  @@index([userId, createdAt])
  @@index([userDidId])
  /// v0.10.26 — Fast unread count queries: SELECT COUNT(*) WHERE userId
  /// AND direction='inbound' AND readAt IS NULL.
  @@index([userId, direction, readAt])
  @@map("messages")
}

// Phase 5.6 — Voicemail.
// Populated by the webhook when Telnyx finishes recording an unanswered call.
model Voicemail {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  user            User      @relation(fields: [userId], references: [id])
  telnyxCallId    String?   @map("telnyx_call_id")
  /// Caller's E.164 number.
  fromNumber      String    @map("from_number")
  /// The DID the caller dialed (our number).
  toNumber        String    @map("to_number")
  recordingUrl    String    @map("recording_url")
  durationSeconds Int       @default(0) @map("duration_seconds")
  transcription   String?
  /// When the caller hung up after leaving the message.
  receivedAt      DateTime  @map("received_at")
  listenedAt      DateTime? @map("listened_at")
  /// v0.10.0 — Which of the user's DIDs this voicemail came in on.
  /// Voicemails are inbound-only by definition; we resolve via the
  /// toNumber match. NULL for legacy rows pre-backfill.
  userDidId       Int?      @map("user_did_id")
  userDid         UserDid?  @relation(fields: [userDidId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  @@index([userId, receivedAt])
  @@index([userDidId])
  @@map("voicemails")
}


// ---------------------------------------------------------------------------
// Internal Chat — dialer users messaging each other (NOT external SMS).
// One row per message. Threads are grouped by the {sender, recipient} pair
// (canonical key = sorted ids joined by '_' so it's the same regardless of
// which side sent the latest message).
// ---------------------------------------------------------------------------
model InternalMessage {
  id          Int       @id @default(autoincrement())
  senderId    Int       @map("sender_id")
  sender      User      @relation("InternalMessageSender", fields: [senderId], references: [id])
  recipientId Int       @map("recipient_id")
  recipient   User      @relation("InternalMessageRecipient", fields: [recipientId], references: [id])
  /// Canonical conversation key — e.g. "3_7" where 3 < 7. Lets us index +
  /// query a 1:1 thread cheaply regardless of which side sent last.
  threadKey   String    @map("thread_key")
  body        String    @default("")
  /// Optional URL to a media attachment (e.g. uploaded image, audio note).
  /// Reuses the Supabase Storage `ace-media` bucket the SMS/MMS flow uses.
  mediaUrl    String?   @map("media_url")
  /// When the recipient first opened the message. Drives the unread count.
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([threadKey, createdAt])
  @@index([recipientId, readAt])
  @@map("internal_messages")
}

// ---------------------------------------------------------------------------
// PendingUser — Pulse-to-ACE migration staging.
//
// Loaded from a CSV upload of existing Pulse users (firstName, lastName,
// email + their Telnyx-side voip_ext / voip_number / ext_password). Rows
// sit here doing NOTHING until an admin explicitly invites a specific user
// via POST /admin/pending-users/:id/invite.
//
// At invite time the admin picks 3 toggles in a modal:
//   1) New DID?            yes = Telnyx API buys a new number
//                          no  = use pulseVoipNumber as-is
//   2) New SIP creds?      yes = Telnyx API creates a fresh Credential
//                                Connection for this user
//                          no  = use pulseVoipExt + pulseExtPassword as-is
//   3) Repoint webhook?    yes = PATCH the Credential Connection's
//                                webhook_event_url from pulse.aptask.com
//                                to ACE's webhook (call logs flow to ACE)
//                          no  = leave webhook on Pulse
//
// Only on Confirm does any Telnyx state change. Successful invite creates
// the real User row, copies linkage into invitedUserId, sets status=invited.
// ---------------------------------------------------------------------------
model PendingUser {
  id                  Int       @id @default(autoincrement())
  firstName           String?   @map("first_name")
  lastName            String?   @map("last_name")
  email               String    @unique
  /// Pulse-side SIP username (CSV: voip_ext). Used as User.sipUsername if
  /// the admin picks "use existing creds" at invite.
  pulseVoipExt        String    @map("pulse_voip_ext")
  /// Pulse-side DID (CSV: voip_number, 10-digit US). Used as User.didNumber
  /// if the admin picks "use existing DID" at invite.
  pulseVoipNumber     String    @map("pulse_voip_number")
  /// Pulse-side SIP password (CSV: ext_password). Used as User.sipPassword
  /// if the admin picks "use existing creds" at invite.
  pulseExtPassword    String    @map("pulse_ext_password")
  /// Telnyx Credential Connection name (CSV: connection_name). Lets us look
  /// up the connection by name when we need to PATCH its webhook URL or
  /// route a new DID to it.
  pulseConnectionName String?   @map("pulse_connection_name")
  /// Pulse-internal status code (CSV: user_status). Kept for reference;
  /// not used by ACE logic.
  pulseUserStatus     String?   @map("pulse_user_status")
  /// Lifecycle: pending (default) → invited (admin clicked Confirm) or
  /// skipped (admin explicitly marked as "don't migrate"). Filter the
  /// admin UI by this column.
  status              String    @default("pending")
  /// When the admin clicked Confirm on the invite modal.
  invitedAt           DateTime? @map("invited_at")
  /// FK to the User row created at invite time. NULL until invited.
  /// Not a relation (avoids cascade-delete weirdness if a User is removed).
  invitedUserId       Int?      @map("invited_user_id")
  /// Each CSV upload gets a fresh UUID-style batch id so we can group
  /// "all rows from this upload" — useful for filtering and for the
  /// audit trail.
  importBatchId       String?   @map("import_batch_id")
  importedAt          DateTime  @default(now()) @map("imported_at")

  @@index([status])
  @@index([email])
  @@index([importBatchId])
  @@map("pending_users")
}

// ---------------------------------------------------------------------------
// AuditLog — enterprise hygiene. Every admin action (invite/promote/demote/
// deactivate/reset-password/role-change) writes a row here. Read-only for
// non-admins; admins see the full feed at Settings → Audit Log.
// ---------------------------------------------------------------------------
model AuditLog {
  id            Int       @id @default(autoincrement())
  /// Who performed the action. NULL only for system-generated entries
  /// (e.g. nightly cleanup jobs); admin actions always have an actor.
  actorUserId   Int?      @map("actor_user_id")
  actor         User?     @relation("AuditLogActor", fields: [actorUserId], references: [id])
  /// Dot-namespaced action verb — e.g. "user.invited", "user.promoted",
  /// "user.demoted", "user.deactivated", "user.password_reset",
  /// "user.sso_first_signin". Keep it sortable + filterable.
  action        String
  /// Which user the action targeted (null for non-user-targeted entries
  /// like "telnyx.webhook_replay_storm").
  targetUserId  Int?      @map("target_user_id")
  target        User?     @relation("AuditLogTarget", fields: [targetUserId], references: [id])
  /// Free-form context — old/new values for diffs, IP address, etc.
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

/// v0.10.22 — Microsoft Graph OAuth tokens for the ACE Bot service account
/// (acebot@aptask.com). Single-row table (key = account email).
///
/// An admin signs in ONCE via /admin/microsoft/oauth/initiate → Microsoft
/// callback stores refresh + access tokens here. From then on, the backend
/// reads this row, refreshes the access token when expired (~1hr), and
/// uses it to call Graph API endpoints (POST /chats, POST /chats/{id}/messages)
/// for Teams DMs. Refresh token lifetime is 90 days sliding — usage extends
/// it indefinitely. If invalidated (password change, conditional access),
/// admin gets a notice and re-signs in.
model MsServiceToken {
  /// The service account's UPN (e.g. "acebot@aptask.com"). Used as the
  /// primary key because we only ever store one account's tokens.
  account       String   @id
  accessToken   String   @map("access_token")
  refreshToken  String   @map("refresh_token")
  /// When the current access token expires. UI shows time-until-refresh.
  expiresAt     DateTime @map("expires_at")
  /// Bumped on every successful refresh; lets admin UI show "last refresh".
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("ms_service_tokens")
}

/// v0.10.52 — Tenant-wide SMS templates curated by admins.
///
/// Used by recruiters when composing outbound SMS — they pick a template
/// from a dropdown in the compose box and the body is inserted with
/// {firstName} pre-filled from the selected contact. Other placeholder
/// variables ({role}, {client}, {time}, etc.) stay as `{varName}` and
/// the user fills them in before sending.
///
/// Tenant-wide by default — all active users see all active templates.
/// Admin curates the list (create, edit, archive). No per-user templates
/// in this iteration; the same playbook covers the whole recruiter team.
model SmsTemplate {
  id          Int      @id @default(autoincrement())
  /// Bucket the template falls under: "outreach" | "docs" | "submission"
  /// | "interview" | "followup" | "outcome" | "bgv" | "relationship" |
  /// "custom". Used for grouping in the picker.
  category    String
  /// Display name shown in the picker (e.g. "Cold outreach").
  name        String
  /// The SMS body itself. May contain {placeholder} variables that get
  /// resolved at send time. Newlines preserved.
  body        String
  /// Sort order within a category. Lower = shown first.
  sortOrder   Int      @default(100) @map("sort_order")
  /// Soft delete — keeps the row for audit + allows un-archive but hides
  /// from the user picker. Admin can also use this to disable templates
  /// without losing the body.
  isActive    Boolean  @default(true) @map("is_active")
  /// User ID of the admin who last touched this row. Nullable for the
  /// initial seed (created by the system "seed defaults" endpoint).
  updatedBy   Int?     @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  @@index([isActive, category, sortOrder])
  @@map("sms_templates")
}

/// v0.10.76 — Tenant-wide library of admin-uploaded ringtones.
///
/// Admin uploads audio files (MP3/WAV) in Settings → Admin → Ringtones;
/// every user sees the full active list in their per-user picker
/// (Settings → Personal → Ringtone). The synthesized presets defined in
/// services/ringtone.ts ('classic' / 'modern' / 'chime' / 'pulse')
/// remain as fallbacks shown alongside any uploads.
///
/// Audio is stored as a base64 data URL in the `dataUrl` column. Same
/// pattern as the v0.10.48 hold-music feature; expects short clips
/// (~3-10s, ~50-200KB) so the embedded data stays manageable in Postgres
/// rows and JSON payloads.
///
/// User.ringtone references either:
///   - synthesized preset slug:  'classic' | 'modern' | 'chime' | 'pulse'
///   - admin upload:             'upload:<id>'  (e.g. 'upload:7')
/// services/ringtone.ts picks playback path based on the prefix.
model Ringtone {
  id          Int      @id @default(autoincrement())
  /// Display label shown in the user picker (e.g. "Office", "Phone Booth").
  name        String
  /// base64 data URL — "data:audio/mpeg;base64,<payload>". Same shape the
  /// hold-music feature uses.
  dataUrl     String   @map("data_url")
  /// Display order within the picker. Lower = shown first. Admin can
  /// reorder by editing this value (UI uses 10/20/30 increments so insert
  /// is cheap).
  sortOrder   Int      @default(100) @map("sort_order")
  /// Soft delete — admin can disable a ringtone without losing the audio,
  /// hides it from the user picker but doesn't break existing User.ringtone
  /// references (services/ringtone.ts falls back to the default preset).
  isActive    Boolean  @default(true) @map("is_active")
  /// User ID of the admin who uploaded it. Nullable for system seeds.
  uploadedBy  Int?     @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("ringtones")
}

/// v0.10.74 — Admin Praise / Announcements.
///
/// Admin-curated celebratory messages (new hire announcement, offer
/// congratulations, birthday wish, work anniversary, custom). Shown to
/// the recipient as a big modal that pops over the dialer once their
/// active call (if any) ends. Two targeting modes:
///   * toUserId set    — one specific recipient
///   * toUserId NULL   — broadcast to everyone (every active ACE user)
///
/// Read state is tracked per-user via PraiseRead so a broadcast praise
/// can be marked read by recipient A without disappearing for recipient
/// B. The "is this praise unread for me?" check is:
///   praise.toUserId == me OR praise.toUserId == NULL
///   AND no PraiseRead row exists for (praise.id, me)
model Praise {
  id            Int       @id @default(autoincrement())
  /// Admin who created it. Always set.
  fromUserId    Int       @map("from_user_id")
  fromUser      User      @relation("PraiseFrom", fields: [fromUserId], references: [id])
  /// Recipient. NULL = broadcast to all active users.
  toUserId      Int?      @map("to_user_id")
  toUser        User?     @relation("PraiseTo", fields: [toUserId], references: [id])
  /// 'new_hire' | 'new_offer' | 'birthday' | 'anniversary' | 'custom'
  /// Drives the icon + default headline. 'custom' lets admin write
  /// arbitrary copy.
  category      String
  /// Display name of the person being celebrated. For a targeted praise
  /// this is usually toUser.firstName + lastName, BUT admin may want to
  /// celebrate someone external to ACE (e.g. a candidate who got an
  /// offer — not an ACE user). For broadcasts this is whoever the praise
  /// is ABOUT (e.g. "Team hit Q2 quota!").
  recipientName String?   @map("recipient_name")
  /// Body of the praise. Free-form (e.g. "on your offer with Mphasis - Puneeth").
  message       String
  createdAt     DateTime  @default(now()) @map("created_at")

  /// Tracks who has dismissed this praise. One row per (praise, user).
  reads         PraiseRead[]

  /// Lookups by recipient for "what unread praises do I have?"
  @@index([toUserId, createdAt])
  /// Lookups by category for analytics ("how many new_hire announcements
  /// did we ship this quarter?")
  @@index([category, createdAt])
  @@map("praises")
}

model PraiseRead {
  id        Int      @id @default(autoincrement())
  praiseId  Int      @map("praise_id")
  praise    Praise   @relation(fields: [praiseId], references: [id], onDelete: Cascade)
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime @default(now()) @map("read_at")

  @@unique([praiseId, userId])
  @@index([userId, readAt])
  @@map("praise_reads")
}

/// v0.10.59 — Schedule an SMS or MMS to send at a future moment.
///
/// One-off only — no recurrence. The worker picks up rows where
/// scheduledFor <= now() AND status='pending', sends via Telnyx, then
/// flips status to 'sent' (and stamps sentAt) or 'failed' (with the error
/// stored in lastError). User can edit/cancel any row in status='pending'.
///
/// Why a dedicated table (vs. piggy-backing on Message with a future
/// sentAt): we want to atomically claim a row when the worker fires —
/// UPDATE ... SET status='sending' WHERE status='pending' AND id=... —
/// and that's awkward against the Message table which has different
/// semantics. Also keeps the scheduled queue logically separate from
/// already-sent history.
model ScheduledMessage {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Recipient (E.164). Same as the threadKey on the Message that will
  /// eventually be created.
  toNumber      String    @map("to_number")
  /// SMS body. Empty string allowed when mediaUrls is non-empty (MMS-only).
  body          String    @default("")
  /// MMS attachment URLs (Supabase Storage public URLs, same format the
  /// immediate-send path uses).
  mediaUrls     String[]  @default([]) @map("media_urls")
  /// When to fire. Stored as UTC timestamp; client picks in their local
  /// timezone and converts.
  scheduledFor  DateTime  @map("scheduled_for")
  /// Which DID to send FROM. Optional — if NULL at send time, worker
  /// uses the user's activeUserDidId (or default DID). Capturing it at
  /// schedule time means a later DID change doesn't surprise-route the
  /// message via a different number.
  userDidId     Int?      @map("user_did_id")
  userDid       UserDid?  @relation(fields: [userDidId], references: [id], onDelete: SetNull)
  /// 'pending' (waiting to fire) | 'sending' (worker claimed it; brief)
  /// | 'sent' (handed to Telnyx) | 'failed' (gave up after retries) |
  /// 'canceled' (user canceled).
  status        String    @default("pending")
  /// How many times the worker has attempted to send. Used to back off
  /// and eventually give up on persistently-failing Telnyx errors.
  attempts      Int       @default(0)
  /// Last error message from Telnyx (when status='failed' or attempts>0).
  lastError     String?   @map("last_error")
  /// telnyxMessageId returned when the send finally succeeded. Null until
  /// then. Links the scheduled row to the resulting Message row.
  telnyxMessageId String?  @map("telnyx_message_id")
  /// When we actually handed it to Telnyx. Null while pending.
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt      @map("updated_at")

  /// Worker query: WHERE status='pending' AND scheduledFor <= now() ORDER BY scheduledFor.
  @@index([status, scheduledFor])
  /// Per-user list (Messages compose UI shows pending count on a thread).
  @@index([userId, status, scheduledFor])
  @@map("scheduled_messages")
}

/// v0.10.48 — Tenant-wide key/value settings table.
///
/// Originally added for hold music: admin uploads a default audio file
/// once, every user inherits it. Stored as base64 data URL in the
/// `value` column (~2-3MB max for typical short hold-music loops).
///
/// Keys in use:
///   "hold_music_data_url"  — base64 data URL of the default hold music
///   "hold_music_filename"  — original filename (display only)
///
/// New keys can be added freely without schema changes.
model SystemSetting {
  /// Setting name. Globally unique. Snake_case by convention.
  key       String   @id
  /// Setting value. May be a short string or a multi-MB base64 blob.
  /// Postgres TEXT type accommodates both; we don't enforce limits here.
  value     String
  /// ACE user id of the admin who last set this. Null for system defaults.
  updatedBy Int?     @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("system_settings")
}
