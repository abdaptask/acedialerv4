{
  "name": "@ace/db",
  "version": "0.10.7",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "generate": "prisma generate",
    "db:push": "dotenv -e ../../.env -- prisma db push --accept-data-loss",
    "db:push:ci": "prisma db push --accept-data-loss",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "seed": "tsx --env-file=../../.env prisma/seed.ts",
    "create-user": "tsx --env-file=../../.env prisma/create-user.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "dotenv-cli": "^8.0.0",
    "prisma": "^5.18.0",
    "tsx": "^4.7.0"
  }
}